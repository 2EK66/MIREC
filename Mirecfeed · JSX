// ============================================================
// REACTION BAR
// ============================================================
function ReactionBar({ post, onReact }) {
  const reactions = [
    { key: "amen",  emoji: "🙏", label: "Amen" },
    { key: "feu",   emoji: "🔥", label: "" },
    { key: "coeur", emoji: "❤️", label: "" },
  ];
  return (
    <div style={{ display: "flex", gap: "8px", flexWrap: "wrap", marginTop: "10px" }}>
      {reactions.map(r => {
        const active = post.user_reactions?.[r.key];
        const count = post.reactions?.[r.key] || 0;
        return (
          <button key={r.key} onClick={() => onReact(post.id, r.key)}
            style={{
              display: "flex", alignItems: "center", gap: "5px",
              padding: "5px 11px", borderRadius: "20px", border: "none",
              background: active ? C.blue50 : C.gray100,
              cursor: "pointer", fontSize: "13px",
              color: active ? C.blue800 : C.gray700,
              fontWeight: active ? "600" : "400",
              transition: "all 0.15s",
              outline: active ? `1.5px solid ${C.blue200}` : "none",
            }}>
            <span style={{ fontSize: "14px" }}>{r.emoji}</span>
            {r.label && <span style={{ fontSize: "12px" }}>{r.label}</span>}
            {count > 0 && <span style={{ fontSize: "12px", fontWeight: "600" }}>{count}</span>}
          </button>
        );
      })}
    </div>
  );
}

