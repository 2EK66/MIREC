      {[
        { label: "Posts", value: posts.length },
        { label: "Prières", value: prayers },
        { label: "Amen", value: totalAmens },
        { label: "Tém.", value: testimonies },
      ].map((s, i) => (
        <div key={i} style={{
          flex: 1, textAlign: "center",
