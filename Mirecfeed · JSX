          <div style={{ fontSize: "11px", color: C.gray500 }}>Communauté · Feed</div>
        </div>
        <button onClick={() => setShowModal(true)}
          style={{
            padding: "9px 18px", borderRadius: "20px", border: "none",
            background: C.blue800, color: C.white,
            fontSize: "13px", fontWeight: "600", cursor: "pointer",
            boxShadow: `0 4px 14px rgba(26,75,155,0.3)`,
          }}>
          + Publier
        </button>
      </div>

      {/* Stats */}
      <FeedHeader posts={posts} />

      {/* Filtres */}
      <FilterTabs active={filter} onChange={setFilter} />

      {/* Liste posts */}
      {loading ? (
        <div style={{ textAlign: "center", padding: "40px", color: C.gray500, fontSize: "14px" }}>
          Chargement du feed…
        </div>
      ) : sorted.length === 0 ? (
        <div style={{ textAlign: "center", padding: "40px", color: C.gray500, fontSize: "14px" }}>
          Aucun post dans cette catégorie.
        </div>
      ) : (
        sorted.map(post => (
          <PostCard
            key={post.id}
            post={post}
            onReact={handleReact}
            onAddComment={handleAddComment}
          />
        ))
      )}

      {/* Modal nouveau post */}
      {showModal && (
        <NewPostModal
          onClose={() => setShowModal(false)}
          onSubmit={handleNewPost}
        />
      )}
    </div>
  );
}

