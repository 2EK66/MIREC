function NewPostModal({ onClose, onSubmit }) {
  const [content, setContent] = useState("");
  const [type, setType] = useState("post");
  const [loading, setLoading] = useState(false);

  const types = [
    { key: "post",         label: "Post", emoji: "💬" },
    { key: "testimony",    label: "Témoignage", emoji: "✨" },
    { key: "prayer",       label: "Prière", emoji: "🙏" },
    { key: "verse",        label: "Verset", emoji: "📖" },
  ];

  const submit = async () => {
    if (!content.trim()) return;
    setLoading(true);
    await onSubmit({ content: content.trim(), type });
    setLoading(false);
    onClose();
  };

  return (
    <div style={{
      position: "fixed", inset: 0, background: "rgba(13,46,107,0.6)",
      display: "flex", alignItems: "flex-end", justifyContent: "center",
      zIndex: 100, padding: "0",
    }}>
      <div style={{
        background: C.white, borderRadius: "24px 24px 0 0", padding: "24px",
        width: "100%", maxWidth: "480px",
      }}>
        <div style={{ display: "flex", justifyContent: "space-between", alignItems: "center", marginBottom: "16px" }}>
          <span style={{ fontSize: "16px", fontWeight: "700", color: C.blue900 }}>Nouveau post</span>
          <button onClick={onClose} style={{ background: "none", border: "none", fontSize: "20px", cursor: "pointer", color: C.gray500 }}>✕</button>
        </div>

        {/* Type selector */}
        <div style={{ display: "flex", gap: "6px", marginBottom: "16px", flexWrap: "wrap" }}>
          {types.map(t => (
            <button key={t.key} onClick={() => setType(t.key)}
              style={{
                padding: "6px 12px", borderRadius: "20px", border: "none",
                background: type === t.key ? C.blue800 : C.gray100,
                color: type === t.key ? C.white : C.gray700,
                fontSize: "12px", cursor: "pointer", fontWeight: type === t.key ? "600" : "400",
              }}>
              {t.emoji} {t.label}
            </button>
          ))}
        </div>

        {/* Textarea */}
        <textarea
          value={content}
          onChange={e => setContent(e.target.value)}
          placeholder={
            type === "prayer" ? "Partage ton sujet de prière avec la communauté..."
            : type === "testimony" ? "Raconte ce que Dieu a fait dans ta vie..."
            : type === "verse" ? "Quel verset veux-tu partager ?"
            : "Qu'est-ce que tu veux partager avec la communauté ?"
          }
          rows={4}
          style={{
            width: "100%", padding: "12px 14px", borderRadius: "12px",
            border: `1.5px solid ${C.gray300}`, fontSize: "14px",
            color: C.gray700, resize: "none", outline: "none",
            lineHeight: "1.6", boxSizing: "border-box",
          }}
        />

        <div style={{ display: "flex", justifyContent: "space-between", alignItems: "center", marginTop: "12px" }}>
          <span style={{ fontSize: "11px", color: C.gray500 }}>{content.length}/500 caractères</span>
          <button onClick={submit} disabled={loading || !content.trim()}
            style={{
              padding: "10px 24px", borderRadius: "20px", border: "none",
              background: loading || !content.trim() ? C.gray300 : C.blue800,
              color: C.white, fontSize: "13px", fontWeight: "700",
              cursor: loading || !content.trim() ? "not-allowed" : "pointer",
            }}>
            {loading ? "Publication…" : "Publier"}
          </button>
        </div>
      </div>
    </div>
  );
}

