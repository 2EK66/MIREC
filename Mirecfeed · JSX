              }}>
                <span style={{ fontWeight: "600", color: C.blue900, marginRight: "6px" }}>
                  {c.profiles.full_name}
                </span>
                {c.content}
              </div>
            </div>
          ))}

          <div style={{ display: "flex", gap: "8px", marginTop: "8px" }}>
            <input
              value={text} onChange={e => setText(e.target.value)}
              onKeyDown={e => e.key === "Enter" && submit()}
