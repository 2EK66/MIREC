// ============================================================
// UTILITAIRES
// ============================================================
function timeAgo(iso) {
  const diff = (Date.now() - new Date(iso)) / 1000;
  if (diff < 60) return "à l'instant";
  if (diff < 3600) return `il y a ${Math.floor(diff / 60)}min`;
  if (diff < 86400) return `il y a ${Math.floor(diff / 3600)}h`;
  return `il y a ${Math.floor(diff / 86400)}j`;
}

function typeConfig(type) {
  switch (type) {
    case "prayer":      return { label: "Prière", color: C.purple, bg: "#F5F3FF" };
    case "testimony":   return { label: "Témoignage", color: C.green, bg: "#ECFDF5" };
    case "announcement":return { label: "Annonce", color: C.blue800, bg: C.blue50 };
    case "verse":       return { label: "Verset du jour", color: C.amber, bg: "#FFFBEB" };
    default:            return { label: "Post", color: C.gray500, bg: C.gray100 };
  }
}

