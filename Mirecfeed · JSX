function FeedHeader({ posts }) {
  const prayers = posts.filter(p => p.type === "prayer").length;
  const testimonies = posts.filter(p => p.type === "testimony").length;
  const totalAmens = posts.reduce((sum, p) => sum + (p.reactions?.amen || 0), 0);

  return (
    <div style={{
      background: `linear-gradient(135deg, ${C.blue900}, ${C.blue800})`,
      borderRadius: "16px", padding: "16px", marginBottom: "16px",
      display: "flex", gap: "0",
