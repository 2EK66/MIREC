// ============================================================
// MAIN AUTH COMPONENT
// ============================================================
export default function MirecAuth() {
  const [mode, setMode] = useState("login"); // login | register | forgot
  const [loading, setLoading] = useState(false);
  const [alert, setAlert] = useState(null); // { type: 'error'|'success', msg }

  // Champs
  const [fullName, setFullName] = useState("");
  const [email, setEmail] = useState("");
  const [password, setPassword] = useState("");
  const [confirm, setConfirm] = useState("");

  // Erreurs inline
  const [errors, setErrors] = useState({});

  const clearAlert = () => setAlert(null);

  // ---- Validation ----
  const validate = () => {
    const e = {};
    if (!email.match(/^[^\s@]+@[^\s@]+\.[^\s@]+$/)) e.email = "Email invalide";
    if (password.length < 6) e.password = "Minimum 6 caractères";
    if (mode === "register") {
      if (!fullName.trim()) e.fullName = "Nom requis";
      if (password !== confirm) e.confirm = "Les mots de passe ne correspondent pas";
    }
    setErrors(e);
    return Object.keys(e).length === 0;
  };

  // ---- Handlers ----
  const handleLogin = async () => {
    if (!validate()) return;

    setLoading(true);
    clearAlert();

    const { data, error } = await supabase.auth.signInWithPassword({
      email,
      password,
    });

    setLoading(false);

    if (error) {
      setAlert({ type: "error", msg: error.message });
    } else {
      setAlert({ type: "success", msg: "Connexion réussie !" });
      console.log("Utilisateur connecté :", data.user);
      // Redirection
      setTimeout(() => {
        window.location.href = "/feed";
      }, 800);
    }
  };

  const handleRegister = async () => {
    if (!validate()) return;
    setLoading(true);
    clearAlert();
    const { error } = await supabase.auth.signUp({
      email,
      password,
      options: { data: { full_name: fullName } }
    });
    setLoading(false);
    if (error) {
      setAlert({ type: "error", msg: error.message });
    } else {
      setAlert({ type: "success", msg: "Compte créé ! Vérifie ton email pour confirmer." });
    }
  };

  const handleForgot = async () => {
    if (!email.match(/^[^\s@]+@[^\s@]+\.[^\s@]+$/)) {
      setErrors({ email: "Entre un email valide" });
      return;
    }
    setLoading(true);
    clearAlert();
    const { error } = await supabase.auth.resetPasswordForEmail({ email });
    setLoading(false);
    if (error) {
      setAlert({ type: "error", msg: error.message });
    } else {
      setAlert({ type: "success", msg: "Lien de réinitialisation envoyé sur " + email });
    }
  };

  const switchMode = (m) => {
    setMode(m);
    setErrors({});
    setAlert(null);
    setPassword("");
    setConfirm("");
  };

  // ============================================================
  // RENDER
  // ============================================================
  return (
    <div style={styles.container}>
      <div style={styles.card}>

        {/* Logo & Nom */}
        <div style={styles.logoZone}>
          <div style={styles.logoCircle}>
            <MirecLogo />
          </div>
          <div style={styles.appName}>MIREC</div>
          <div style={styles.tagline}>
            {mode === "forgot"
              ? "Réinitialiser le mot de passe"
              : "Communauté de foi · Cotonou"}
          </div>
        </div>

        {/* Tabs login/inscription */}
        {mode !== "forgot" && (
          <div style={styles.tabRow}>
            <button style={styles.tabBtn(mode === "login")} onClick={() => switchMode("login")}>
              Connexion
            </button>
            <button style={styles.tabBtn(mode === "register")} onClick={() => switchMode("register")}>
              Inscription
            </button>
          </div>
        )}

        {/* Alert */}
        {alert && (
          <div style={styles.alertBox(alert.type)}>
            {alert.type === "success" ? "✓ " : "⚠ "}{alert.msg}
          </div>
        )}

        {/* ---- FORGOT PASSWORD ---- */}
        {mode === "forgot" && (
          <>
            <Input label="Adresse email" type="email" value={email} onChange={setEmail}
              placeholder="ton@email.com" error={errors.email} autoComplete="email" />
            <button style={styles.submitBtn(loading)} onClick={handleForgot} disabled={loading}>
              {loading ? "Envoi en cours…" : "Envoyer le lien"}
            </button>
            <div style={{ textAlign: "center", marginTop: "16px" }}>
              <button style={styles.forgotBtn} onClick={() => switchMode("login")}>
                ← Retour à la connexion
              </button>
            </div>
          </>
        )}

        {/* ---- LOGIN ---- */}
        {mode === "login" && (
          <>
            <Input label="Adresse email" type="email" value={email} onChange={v => { setEmail(v); setErrors(e => ({ ...e, email: null })); }}
              placeholder="ton@email.com" error={errors.email} autoComplete="email" />
            <Input label="Mot de passe" type="password" value={password} onChange={v => { setPassword(v); setErrors(e => ({ ...e, password: null })); }}
              placeholder="••••••••" error={errors.password} autoComplete="current-password" />
            <button style={styles.forgotBtn} onClick={() => switchMode("forgot")}>
              Mot de passe oublié ?
            </button>
            <button style={styles.submitBtn(loading)} onClick={handleLogin} disabled={loading}>
              {loading ? "Connexion…" : "Se connecter"}
            </button>
          </>
        )}

        {/* ---- REGISTER ---- */}
        {mode === "register" && (
          <>
            <Input label="Nom complet" type="text" value={fullName} onChange={v => { setFullName(v); setErrors(e => ({ ...e, fullName: null })); }}
              placeholder="Jean-Baptiste Koffi" error={errors.fullName} autoComplete="name" />
            <Input label="Adresse email" type="email" value={email} onChange={v => { setEmail(v); setErrors(e => ({ ...e, email: null })); }}
              placeholder="ton@email.com" error={errors.email} autoComplete="email" />
            <Input label="Mot de passe" type="password" value={password} onChange={v => { setPassword(v); setErrors(e => ({ ...e, password: null })); }}
              placeholder="Minimum 6 caractères" error={errors.password} autoComplete="new-password" />
            <Input label="Confirmer le mot de passe" type="password" value={confirm} onChange={v => { setConfirm(v); setErrors(e => ({ ...e, confirm: null })); }}
              placeholder="••••••••" error={errors.confirm} autoComplete="new-password" />

            <div style={{ fontSize: "11px", color: COLORS.gray400, marginBottom: "14px", lineHeight: "1.5", fontFamily: "system-ui, sans-serif" }}>
              En créant un compte, tu rejoins la communauté MIREC et acceptes les conditions d'utilisation.
            </div>

            <button style={styles.submitBtn(loading)} onClick={handleRegister} disabled={loading}>
              {loading ? "Création du compte…" : "Rejoindre MIREC"}
            </button>
          </>
        )}

        {/* Divider décoratif */}
        {mode !== "forgot" && (
          <div style={styles.divider}>
            <div style={styles.dividerLine} />
            <span style={styles.dividerText}>MIREC</span>
            <div style={styles.dividerLine} />
          </div>
        )}

        {/* Verset du bas */}
        {mode !== "forgot" && (
          <div style={{ textAlign: "center", fontSize: "11px", color: COLORS.gray400, fontStyle: "italic", lineHeight: "1.6", fontFamily: "'Georgia', serif" }}>
            "Car là où deux ou trois sont réunis en mon nom,<br />
            je suis au milieu d'eux." — Mat. 18:20
          </div>
        )}
      </div>

      {/* Footer */}
      <div style={styles.footer}>
        MIREC · Application communautaire · v1.0
      </div>
    </div>
  );
}
