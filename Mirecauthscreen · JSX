// ============================================================
// INPUT COMPONENT
// ============================================================
function Input({ label, type = "text", value, onChange, placeholder, error, autoComplete }) {
  const [focused, setFocused] = useState(false);
  const [shown, setShown] = useState(false);
  const isPassword = type === "password";

  return (
    <div>
      <label style={styles.label}>{label}</label>
      <div style={styles.inputWrap(focused, !!error)}>
        <input
          type={isPassword && shown ? "text" : type}
          value={value}
          onChange={e => onChange(e.target.value)}
          onFocus={() => setFocused(true)}
          onBlur={() => setFocused(false)}
          placeholder={placeholder}
          autoComplete={autoComplete}
          style={{ ...styles.input, paddingRight: isPassword ? "42px" : "14px" }}
        />
        {isPassword && (
          <button style={styles.eyeBtn} onClick={() => setShown(s => !s)} type="button">
            {shown ? "🙈" : "👁"}
          </button>
        )}
      </div>
      {error && <span style={styles.errorText}>{error}</span>}
    </div>
  );
}

